# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Public production configuration. Keep provider API tokens in app settings, never in the APK.
# Export these as build environment variables for production:
# DRDUC_GRAPH_URL=https://cdn.example/translation_graph.mobile.sqlite
# DRDUC_GRAPH_SHA256=6e27ead3142a4a0da3073aaea368974a007ec32da9e32157565af69f23072095
# DRDUC_ONLINE_URL=https://provider.example/v1/chat/completions
# DRDUC_ONLINE_MODEL=<model id>
