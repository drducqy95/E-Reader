{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://drduc.local/schema/overlay-delta-v2.json",
  "title": "DrDuc Android Overlay Delta Manifest V2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "baseGraphVersion",
    "deltaVersion",
    "sha256",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "baseGraphVersion": {
      "type": "string",
      "minLength": 1
    },
    "deltaVersion": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50000,
      "items": {
        "$ref": "#/definitions/entry"
      }
    }
  },
  "definitions": {
    "entry": {
      "type": "object",
      "required": [
        "type",
        "reviewed",
        "source",
        "target"
      ],
      "properties": {
        "type": {
          "enum": [
            "term",
            "tm"
          ]
        },
        "reviewed": {
          "const": true
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "universe": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "entityType": {
          "type": "string"
        },
        "posTag": {
          "type": "string"
        },
        "posSub": {
          "type": "string"
        },
        "grammarRole": {
          "type": "string"
        },
        "contextMarkers": {
          "$ref": "#/definitions/stringList"
        },
        "negativeContextMarkers": {
          "$ref": "#/definitions/stringList"
        },
        "coOccurringEntities": {
          "$ref": "#/definitions/stringList"
        }
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
